{
  "name": "smart-data-analysis",
  "version": "1.1.0",
  "openclaw": {
    "skillKey": "smart-data-analysis"
  },
  "description": "数据分析总入口编排：先做环境检测与配置检查，再按意图路由到找表（smart-search-tables）、问数（smart-ask-data）、数据洞察（smart-data-insights，含解读/维度/对比/归因子场景）、报告（smart-reporting）子流程；execute-code-sync/json2plot 仅在 smart-data-insights 归因子场景等明确允许处按需触发。",
  "defaults": {
    "x_business_domain": "bd_public",
    "progress_template": "## 📋 任务进度清单（阶段：{flow}）\n- [ ] 待完成 · 步骤{step}（{name}）\n- [ ] 待完成 · 下一步（{next}）"
  },
  "tools": {
    "smart_search_tables": {
      "type": "subskill",
      "reference": "skills/smart-data-analysis/references/smart-search-tables.md"
    },
    "smart_ask_data": {
      "type": "subskill",
      "reference": "skills/smart-data-analysis/references/smart-ask-data.md"
    },
    "smart_data_insights": {
      "type": "subskill",
      "reference": "skills/smart-data-analysis/references/smart-data-insights.md"
    },    
    "smart_reporting": {
      "type": "subskill",
      "reference": "skills/smart-data-analysis/references/smart-reporting.md"
    },
    "execute_code_sync": {
      "type": "subskill",
      "reference": "skills/smart-data-analysis/references/execute-code-sync.md",
      "url_path": "/api/v1/executions/sessions/sess-agent-default/execute-sync"
    },
    "smart_json2plot": {
      "type": "subskill",
      "reference": "skills/smart-data-analysis/references/smart-json2plot.md",
      "url_path": "/api/af-sailor-agent/v1/assistant/tools/json2plot"
    }
  },
  "pipeline": [
    {
      "step": 1,
      "role": "environment_check",
      "flow": "smart-data-analysis",
      "required": true
    },
    {
      "step": 2,
      "role": "config_check",
      "flow": "smart-data-analysis",
      "required": true,
      "source": "SOUL.md"
    },
    {
      "step": 3,
      "role": "intent_routing",
      "flow": "smart-data-analysis",
      "required": true
    },
    {
      "step": 4,
      "role": "dispatch_subflow",
      "flow": "smart-data-analysis",
      "required": true
    },
    {
      "step": 5,
      "role": "find_tables",
      "flow": "smart-search-tables",
      "trigger": "intent=find_table",
      "reference": "skills/smart-data-analysis/references/smart-search-tables.md"
    },
    {
      "step": 5,
      "role": "ask_data",
      "flow": "smart-ask-data",
      "trigger": "intent=ask_data",
      "reference": "skills/smart-data-analysis/references/smart-ask-data.md"
    },
    {
      "step": 5,
      "role": "data_insights",
      "flow": "smart-data-insights",
      "trigger": "intent=data_insights",
      "reference": "skills/smart-data-analysis/references/smart-data-insights.md"
    },
    {
      "step": 5,
      "role": "generate_report",
      "flow": "smart-reporting",
      "trigger": "intent=reporting",
      "reference": "skills/smart-data-analysis/references/smart-reporting.md"
    },
    {
      "step": 11,
      "role": "post_process_code",
      "flow": "smart-ask-data",
      "trigger": "intent=ask_data and need_post_process=true",
      "optional": true,
      "reference": "skills/smart-data-analysis/references/execute-code-sync.md"
    },
    {
      "step": 11,
      "role": "chart_data",
      "flow": "smart-ask-data",
      "trigger": "intent=ask_data and need_chart=true",
      "optional": true,
      "reference": "skills/smart-data-analysis/references/smart-json2plot.md"
    }
  ]
}